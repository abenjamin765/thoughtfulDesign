---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AuthGuard from '../../../components/AuthGuard';
import SignOutButton from '../../../components/SignOutButton';
import LessonRow from '../../../components/LessonRow.astro';
import LessonStatus from '../../../components/LessonStatus';
import ModuleAssessmentCard from '../../../components/ModuleAssessmentCard';
import {
  getAllModules,
  getModule,
  getPartForModule,
  getModuleLessons,
  getAssessmentPath,
} from '../../../lib/course';
import { getLessonSlug } from '../../../lib/lessons';
import { withBase } from '../../../lib/paths';

export async function getStaticPaths() {
  return getAllModules().map((module) => ({ params: { slug: module.id } }));
}

const { slug } = Astro.params;
const module = getModule(slug);

if (!module) {
  return Astro.redirect(withBase('/course'));
}

const part = getPartForModule(module.id);
const lessons = (await getModuleLessons(module.id)).filter((l) => l.data.published);
const lessonSlugs = lessons.map(getLessonSlug);
const totalMinutes = lessons.reduce((sum, l) => sum + (l.data.estimated_minutes ?? 0), 0);

// Module assessment metadata (Phase 4 owns the runner route; we only read the
// content here for the question count + pass threshold shown on the card).
const assessments = await getCollection('assessments');
const assessment = assessments.find(
  (entry) => entry.data.type === 'module' && entry.data.id === module.id,
);
const questionCount = assessment?.data.questions?.length ?? 0;
const passThreshold = assessment?.data.pass_threshold ?? 0.8;
const assessmentHref = withBase(getAssessmentPath('module', module.id));
---

<BaseLayout title={`${module.title} — Thoughtful Design`}>
  <AuthGuard client:load>
    <article class="container" style="padding: 2.5rem 0;">
      <div style="display: flex; justify-content: space-between; gap: 1rem; align-items: center; flex-wrap: wrap;">
        <a href={withBase('/course')} class="muted">← All modules</a>
        <SignOutButton client:load />
      </div>

      <header class="module-header">
        <p class="module-header__eyebrow muted">
          {part ? `Part ${part.order} · ${part.name} · ` : ''}Module {module.order}
        </p>
        <h1>{module.title}</h1>
        <blockquote class="module-header__claim">{module.core_claim}</blockquote>

        <div class="module-header__meta">
          <span>{lessons.length} {lessons.length === 1 ? 'lesson' : 'lessons'}</span>
          {totalMinutes > 0 && <span>{totalMinutes} min total</span>}
        </div>

        {module.loop_steps && module.loop_steps.length > 0 && (
          <div class="loop-steps" aria-label="Thoughtful Design Loop steps in this module">
            {module.loop_steps.map((step) => (
              <span class="loop-steps__chip">{step}</span>
            ))}
          </div>
        )}
      </header>

      <section class="module-lessons">
        <h2>Lessons</h2>
        {lessons.length === 0 ? (
          <p class="muted">Lessons coming soon.</p>
        ) : (
          <div class="lesson-rows">
            {lessons.map((lesson) => {
              const lessonSlug = getLessonSlug(lesson);
              return (
                <LessonRow
                  title={lesson.data.title}
                  href={withBase(`/lessons/${lessonSlug}`)}
                  number={lesson.data.order}
                  estimatedMinutes={lesson.data.estimated_minutes}
                  slug={lessonSlug}
                >
                  <LessonStatus slot="status" client:load slug={lessonSlug} />
                </LessonRow>
              );
            })}
          </div>
        )}
      </section>

      <section class="module-assessment">
        <ModuleAssessmentCard
          client:load
          assessmentId={module.id}
          assessmentHref={assessmentHref}
          lessonSlugs={lessonSlugs}
          questionCount={questionCount}
          passThreshold={passThreshold}
        />
      </section>
    </article>
  </AuthGuard>
</BaseLayout>

<style>
  .module-header {
    margin: 1.5rem 0 2.5rem;
  }

  .module-header__eyebrow {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin: 0 0 0.5rem;
  }

  .module-header h1 {
    margin: 0 0 1rem;
  }

  .module-header__claim {
    font-family: var(--font-serif);
    font-size: var(--step-2);
    line-height: 1.3;
    margin: 0 0 1.25rem;
    padding: 0.75rem 1.25rem;
    border-left: 4px solid var(--accent);
    background: var(--accent-soft);
    border-radius: 0 var(--radius) var(--radius) 0;
    max-width: var(--measure);
  }

  .module-header__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    color: var(--muted);
    font-size: 0.95rem;
  }

  .loop-steps {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .loop-steps__chip {
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.2rem 0.7rem;
    border-radius: 999px;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--accent);
  }

  .module-lessons {
    margin-bottom: 2.5rem;
  }

  .module-lessons h2 {
    margin-bottom: 1rem;
  }

  .lesson-rows {
    display: grid;
    gap: 0.75rem;
  }
</style>
