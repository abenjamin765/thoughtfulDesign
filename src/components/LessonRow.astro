---
// Shared lesson row. Presentational and reused across the module index and the
// dashboard progress section (wireframe §Component Reuse Notes). Per-user
// completion state is injected via the `status` slot (a client island), so the
// row markup itself stays static and identical across surfaces.
//
// API:
//   <LessonRow
//     number={1}
//     title="The Dashboard Request"
//     href="/lessons/the-dashboard-request"
//     estimatedMinutes={8}
//     slug="the-dashboard-request"
//   >
//     <LessonStatus slot="status" client:load slug="the-dashboard-request" />
//   </LessonRow>
interface Props {
  title: string;
  href: string;
  number?: number;
  estimatedMinutes?: number;
  slug?: string;
}

const { title, href, number, estimatedMinutes, slug } = Astro.props;
---

<a class="lesson-row" href={href} data-lesson-slug={slug}>
  <span class="lesson-row__main">
    {number != null && <span class="lesson-row__number muted">{number}</span>}
    <span class="lesson-row__text">
      <strong>{title}</strong>
      {estimatedMinutes ? (
        <span class="lesson-row__meta muted">{estimatedMinutes} min</span>
      ) : null}
    </span>
  </span>
  <span class="lesson-row__status">
    <slot name="status" />
  </span>
</a>

<style>
  .lesson-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 0.9rem 1.1rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: inherit;
    text-decoration: none;
    transition: border-color 0.15s ease;
  }

  .lesson-row:hover {
    border-color: var(--accent);
  }

  .lesson-row__main {
    display: flex;
    align-items: baseline;
    gap: 0.85rem;
    min-width: 0;
  }

  .lesson-row__number {
    font-variant-numeric: tabular-nums;
    font-weight: 700;
  }

  .lesson-row__text {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 0;
  }

  .lesson-row__meta {
    font-size: 0.85rem;
  }

  .lesson-row__status {
    flex-shrink: 0;
    font-size: 0.85rem;
  }
</style>
